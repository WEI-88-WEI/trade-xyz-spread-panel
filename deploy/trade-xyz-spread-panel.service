[Unit]
Description=trade-xyz-spread-panel backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/.openclaw/workspace/trade-xyz-spread-panel
Environment=NODE_ENV=production
Environment=PORT=8787
ExecStart=/home/ubuntu/nvm/versions/node/v24.14.0/bin/node /home/ubuntu/.openclaw/workspace/trade-xyz-spread-panel/server/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
